# ─── EmailJS (Client-side) ────────────────────────────────────────────────────
NEXT_PUBLIC_EMAILJS_SERVICE_ID=your_service_id
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=your_public_key
NEXT_PUBLIC_EMAILJS_TEMPLATE_CLIENT=your_template_client_id
NEXT_PUBLIC_EMAILJS_TEMPLATE_OWNER=your_template_owner_id

# ─── EmailJS (Server-side — para el Webhook) ──────────────────────────────────
# Obtén la Private Key en: https://dashboard.emailjs.com/admin/account
EMAILJS_SERVICE_ID=your_service_id
EMAILJS_TEMPLATE_CLIENT=your_template_client_id
EMAILJS_TEMPLATE_OWNER=your_template_owner_id
EMAILJS_PRIVATE_KEY=your_private_key

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Client (public)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Server-side (Service Role — más permisos, solo en el backend)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...

# ─── MercadoPago ──────────────────────────────────────────────────────────────
# Token secreto del servidor (NUNCA exponer al cliente)
# Obtén en: https://www.mercadopago.com.ar/developers → Credenciales de producción
MP_ACCESS_TOKEN=APP_USR-xxxx-xxxx-xxxx-xxxx

# ─── URL Base del sitio ───────────────────────────────────────────────────────
# Usado para generar back_urls de MercadoPago y URLs del Webhook
NEXT_PUBLIC_BASE_URL=https://teloimprimo.cl

# ─── API Express (apps/api) — Solo para desarrollo local ─────────────────────
# MP_ACCESS_TOKEN se reutiliza arriba
SUPABASE_KEY=eyJ...   # Mismo que SUPABASE_SERVICE_KEY
CORS_ORIGIN=http://localhost:3000
BASE_URL=http://localhost:3000
PORT=3001
